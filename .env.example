# WebObsidian environment
PORT=8787
HOST=0.0.0.0
# Absolute path to the vault directory (mounted in docker)
VAULT_PATH=./sample-vault
# Directory for runtime config/index (settings.json lives here)
DATA_DIR=./data
# Optional: set initial master password (otherwise set on first-run via UI)
WEBOBSIDIAN_PASSWORD=
# Comma-separated absolute roots the vault picker is allowed to browse
ALLOWED_ROOTS=
NODE_ENV=production
